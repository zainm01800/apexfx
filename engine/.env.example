# APEX Quant Engine — environment overrides (optional)
# Copy to .env and adjust. Anything here overrides config.yaml.
# Nested keys use double underscore.

# APEX_SEED=42
# APEX_RISK__KELLY_FRACTION=0.25
# APEX_RISK__MAX_RISK_PER_TRADE=0.01
# APEX_DATA__TIMEFRAME=1d

# CORS origin for the FastAPI service (frontend dev server). Comma-separated.
# APEX_CORS_ORIGINS=http://localhost:3001,http://127.0.0.1:3001
